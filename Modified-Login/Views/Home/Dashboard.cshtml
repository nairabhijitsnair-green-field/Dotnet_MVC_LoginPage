@{
    ViewData["Title"] = "Dashboard";
}

<style>
    :root {
        --emerald-blue: #0d9488;
        --dark-emerald: #064e3b;
        --bg-gradient: linear-gradient(135deg, #0f172a 0%, #0d9488 100%);
    }

    body {
        background: var(--bg-gradient);
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        color: #1e293b;
    }

    .dashboard-container {
        max-width: 900px;
        margin: 50px auto;
        padding: 20px;
    }

    .welcome-card {
        background: white;
        border-radius: 1.5rem;
        padding: 3rem;
        text-align: center;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    .avatar-circle {
        width: 80px;
        height: 80px;
        background: var(--soft-bg, #f0fdfa);
        color: var(--emerald-blue);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: bold;
        margin: 0 auto 1.5rem;
        border: 2px solid var(--emerald-blue);
    }

    h1 {
        color: var(--dark-emerald);
        font-size: 2.2rem;
        margin-bottom: 0.5rem;
    }

    p.subtitle {
        color: #64748b;
        margin-bottom: 2rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    .stat-box {
        background: #f8fafc;
        padding: 1.5rem;
        border-radius: 1rem;
        border: 1px solid #e2e8f0;
    }

        .stat-box span {
            display: block;
            font-size: 0.8rem;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stat-box strong {
            font-size: 1.5rem;
            color: var(--emerald-blue);
        }

    .btn-logout {
        display: inline-block;
        padding: 0.75rem 2rem;
        background-color: #ef4444; 
        color: white;
        text-decoration: none;
        border-radius: 0.5rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-logout:hover {
            background-color: #b91c1c;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
        }
</style>

<div class="dashboard-container">
    <div class="welcome-card">
        <div class="avatar-circle">
            @(string.IsNullOrEmpty(ViewBag.Name) ? "?" : ViewBag.Name.Substring(0, 1).ToUpper())
        </div>

        <h1>Welcome, @ViewBag.Name!</h1>
        <p class="subtitle">You have successfully accessed your secure dashboard.</p>

        <div class="stats-grid">
            <div class="stat-box">
                <span>Status</span>
                <strong>Active</strong>
            </div>
            <div class="stat-box">
                <span>Account Type</span>
                <strong>Standard</strong>
            </div>
            <div class="stat-box">
                <span>Last Login</span>
                <strong>Today</strong>
            </div>
        </div>

        <a asp-controller="Account" asp-action="Logout" class="btn-logout">Logout System</a>
    </div>
</div>